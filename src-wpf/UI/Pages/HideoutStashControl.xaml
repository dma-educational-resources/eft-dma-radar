<UserControl x:Class="eft_dma_radar.UI.Pages.HideoutStashControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="560" d:DesignWidth="540"
             MinWidth="340" MinHeight="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header / drag handle -->
        <Border x:Name="DragHandle" Grid.Row="0" Style="{StaticResource PanelHeader}"
                MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Hideout" Style="{StaticResource PanelHeaderText}"/>
                <Button x:Name="BtnRefresh" Grid.Column="1"
                        Style="{StaticResource ButtonIcon}"
                        ToolTip="Refresh stash items and area upgrades"
                        Width="26" Height="26" Margin="0,0,5,0"
                        hc:IconElement.Width="14"
                        hc:IconElement.Geometry="{StaticResource ArrowsRotateGeometry}"
                        Click="BtnRefresh_Click"/>
                <Border Grid.Column="2" Style="{StaticResource CloseButtonBorder}">
                    <Button x:Name="BtnClose" Style="{StaticResource CloseButton}" Click="BtnClose_Click"/>
                </Border>
            </Grid>
        </Border>

        <!-- GOM setup hint -->
        <Border Grid.Row="1" Background="#08FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="0,0,0,1" Padding="10,5">
            <TextBlock FontSize="10" Opacity="0.50" TextWrapping="Wrap" LineHeight="15">
                <Run FontWeight="Bold">ℹ</Run>
                <Run>Visit your hideout at least once after game start and after every raid before refreshing — you can refresh while inside the hideout or from the main menu. HideoutArea / HideoutController are not present in the GOM during a raid or on first launch.</Run>
            </TextBlock>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">
            <Border Background="{DynamicResource RegionBrush}" CornerRadius="0,0,8,8"/>

            <TabControl Margin="0" Background="Transparent" BorderThickness="0"
                        Padding="0" TabStripPlacement="Top">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                        <Setter Property="Padding" Value="12,4"/>
                        <Setter Property="FontSize" Value="12"/>
                    </Style>
                </TabControl.Resources>

                <!-- ══════════════════ STASH TAB ══════════════════ -->
                <TabItem Header="Stash">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Totals bar -->
                        <Border Grid.Row="0" Background="{DynamicResource DarkPrimaryBrush}"
                                Margin="8,6,8,0" CornerRadius="4" Padding="10,6" Opacity="0.9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="TRADER" FontSize="9" Opacity="0.5" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtTraderTotal" Text="–" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="FLEA" FontSize="9" Opacity="0.5" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtFleaTotal" Text="–" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="BEST" FontSize="9" Opacity="0.5" FontWeight="Bold" Foreground="#F0C040"/>
                                    <TextBlock x:Name="TxtBestTotal" Text="–" FontSize="13" FontWeight="Bold" Foreground="#F0C040"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtItemCount" Grid.Column="3"
                                           FontSize="10" Opacity="0.5" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <!-- Search + group toggle -->
                        <Grid Grid.Row="1" Margin="8,6,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <hc:TextBox Grid.Column="0"
                                        x:Name="SearchBox"
                                        hc:InfoElement.Placeholder="Search items..."
                                        TextChanged="SearchBox_TextChanged"/>
                            <CheckBox Grid.Column="1"
                                      x:Name="ChkGroup"
                                      Content="Group"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Checked="ChkGroup_Changed"
                                      Unchecked="ChkGroup_Changed"/>
                        </Grid>

                        <!-- Items grid -->
                        <DataGrid x:Name="StashGrid"
                                  Grid.Row="2"
                                  Margin="8,6,8,8"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                  HeadersVisibility="Column"
                                  RowHeight="26"
                                  FontSize="12"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#0AFFFFFF">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"   Binding="{Binding Name}"      Width="*"   SortMemberPath="Name"/>
                                <DataGridTextColumn Header="Qty"    Binding="{Binding StackCount}" Width="34"  SortMemberPath="StackCount"/>
                                <DataGridTemplateColumn Header="Trader" Width="110" SortMemberPath="TraderRaw" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TraderFmt}" FontSize="12" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding TraderName}" FontSize="10" Opacity="0.55" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Flea"   Binding="{Binding FleaFmt}"    Width="72"  SortMemberPath="FleaRaw"/>
                                <DataGridTextColumn Header="Best"   Binding="{Binding BestFmt}"    Width="72"  SortMemberPath="BestRaw">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SellOnFlea}" Value="True">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Sell"   Binding="{Binding SellOn}"     Width="46"  SortMemberPath="SellOnFlea"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- UPGRADES TAB -->
                <TabItem Header="Upgrades">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Summary bar -->
                        <Border Grid.Row="0" Background="{DynamicResource DarkPrimaryBrush}"
                                Margin="8,6,8,0" CornerRadius="4" Padding="10,6" Opacity="0.9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtUpgradeCount"
                                           Grid.Column="0"
                                           Text="Press Refresh to load hideout data"
                                           FontSize="11" Opacity="0.6"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkMarkInRaid"
                                          Grid.Column="1"
                                          Content="Mark in raid"
                                          FontSize="11"
                                          VerticalAlignment="Center"
                                          ToolTip="Highlight needed items on the radar while in raid"
                                          Checked="ChkMarkInRaid_Changed"
                                          Unchecked="ChkMarkInRaid_Changed"/>
                            </Grid>
                        </Border>

                        <!-- Areas list -->
                        <ScrollViewer Grid.Row="1"
                                      Margin="8,6,8,8"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="UpgradesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,3" Padding="8,6"
                                                CornerRadius="4" Background="#0CFFFFFF"
                                                Opacity="{Binding RowOpacity}">
                                            <StackPanel>

                                                <!-- Area header row -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding AreaName}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding LevelLabel}"
                                                               FontSize="11" Opacity="0.55"
                                                               Margin="6,0,8,0"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="2"
                                                            Background="#14FFFFFF"
                                                            CornerRadius="3"
                                                            Padding="5,1">
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Requirements list -->
                                                <ItemsControl ItemsSource="{Binding Requirements}"
                                                              Visibility="{Binding RequirementsVisibility}"
                                                              Margin="2,5,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="14"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding FulfilledIcon}"
                                                                           FontSize="10" FontWeight="Bold"
                                                                           Foreground="{Binding FulfilledBrush}"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Description}"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Resize handle -->
            <Grid Style="{StaticResource ResizeHandle}"
                  MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown">
                <Path Style="{StaticResource ResizeHandleIcon}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
