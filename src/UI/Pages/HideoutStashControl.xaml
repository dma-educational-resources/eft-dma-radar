<UserControl x:Class="eft_dma_radar.UI.Pages.HideoutStashControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="540" d:DesignWidth="540"
             MinWidth="340" MinHeight="240">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header / drag handle -->
        <Border x:Name="DragHandle" Grid.Row="0" Style="{StaticResource PanelHeader}"
                MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Hideout Stash" Style="{StaticResource PanelHeaderText}"/>
                <Button x:Name="BtnRefresh" Grid.Column="1"
                        Style="{StaticResource ButtonIcon}"
                        ToolTip="Refresh stash items"
                        Width="26" Height="26" Margin="0,0,5,0"
                        hc:IconElement.Width="14"
                        hc:IconElement.Geometry="{StaticResource ArrowsRotateGeometry}"
                        Click="BtnRefresh_Click"/>
                <Border Grid.Column="2" Style="{StaticResource CloseButtonBorder}">
                    <Button x:Name="BtnClose" Style="{StaticResource CloseButton}" Click="BtnClose_Click"/>
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Border Background="{DynamicResource RegionBrush}" CornerRadius="0,0,8,8"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Totals bar -->
                <Border Grid.Row="0" Background="{DynamicResource DarkPrimaryBrush}"
                        Margin="8,8,8,0" CornerRadius="4" Padding="10,6" Opacity="0.9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TRADER" FontSize="9" Opacity="0.5" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTraderTotal" Text="–" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="FLEA" FontSize="9" Opacity="0.5" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtFleaTotal" Text="–" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="BEST" FontSize="9" Opacity="0.5" FontWeight="Bold" Foreground="#F0C040"/>
                            <TextBlock x:Name="TxtBestTotal" Text="–" FontSize="13" FontWeight="Bold" Foreground="#F0C040"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtItemCount" Grid.Column="3"
                                   FontSize="10" Opacity="0.5" VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <!-- Search + group toggle -->
                <Grid Grid.Row="1" Margin="8,6,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <hc:TextBox Grid.Column="0"
                                x:Name="SearchBox"
                                hc:InfoElement.Placeholder="Search items..."
                                TextChanged="SearchBox_TextChanged"/>
                    <CheckBox Grid.Column="1"
                              x:Name="ChkGroup"
                              Content="Group"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Checked="ChkGroup_Changed"
                              Unchecked="ChkGroup_Changed"/>
                </Grid>

                <!-- Items grid -->
                <DataGrid x:Name="StashGrid"
                          Grid.Row="2"
                          Margin="8,6,8,8"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          HeadersVisibility="Column"
                          RowHeight="26"
                          FontSize="12"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0AFFFFFF">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"   Binding="{Binding Name}"      Width="*"   SortMemberPath="Name"/>
                        <DataGridTextColumn Header="Qty"    Binding="{Binding StackCount}" Width="34"  SortMemberPath="StackCount"/>
                        <DataGridTextColumn Header="Trader" Binding="{Binding TraderFmt}"  Width="72"  SortMemberPath="TraderRaw"/>
                        <DataGridTextColumn Header="Flea"   Binding="{Binding FleaFmt}"    Width="72"  SortMemberPath="FleaRaw"/>
                        <DataGridTextColumn Header="Best"   Binding="{Binding BestFmt}"    Width="72"  SortMemberPath="BestRaw">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SellOnFlea}" Value="True">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Sell"   Binding="{Binding SellOn}"     Width="46"  SortMemberPath="SellOnFlea"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Resize handle -->
            <Grid Style="{StaticResource ResizeHandle}"
                  MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown">
                <Path Style="{StaticResource ResizeHandleIcon}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
