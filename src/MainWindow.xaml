<Window x:Class="eft_dma_radar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:local="clr-namespace:eft_dma_radar.UI.Pages"
        mc:Ignorable="d"
        Title="EFT DMA Radar"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Height="720"
        Width="1280"
        StateChanged="Window_StateChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#9E2315"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="TitleBar" Height="32" VerticalAlignment="Top" Panel.ZIndex="9999"
              Background="{DynamicResource RegionBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="{StaticResource AppIconImage}"
                   Width="20" Height="20" Margin="8,0,0,0" VerticalAlignment="Center"
                   WindowChrome.IsHitTestVisibleInChrome="False"/>
            <TextBlock x:Name="TitleTextBlock" Grid.Column="1" Text="EFT DMA Radar"
                       VerticalAlignment="Center" Margin="8,0,0,0"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       WindowChrome.IsHitTestVisibleInChrome="False"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="btnMinimize"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Content="&#xE949;"
                        ToolTip="Minimize"
                        Click="btnMinimize_Click"/>
                <Button x:Name="btnMaximizeRestore"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Content="&#xE739;"
                        ToolTip="Maximize"
                        Click="btnMaximizeRestore_Click"/>
                <Button x:Name="btnClose"
                        Style="{StaticResource TitleBarCloseButtonStyle}"
                        Content="&#xE8BB;"
                        ToolTip="Close"
                        Click="btnClose_Click"/>
            </StackPanel>
        </Grid>
        <Grid Name="mainContentGrid" Margin="0,32,0,0">
            <skia:SKGLElement x:Name="skCanvas"/>
            <skia:SKElement x:Name="skCanvasCpu" Visibility="Collapsed"/>
        </Grid>

        <Canvas Name="ToolbarCanvas" Panel.ZIndex="1500">
            <Border x:Name="customToolbar"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            Canvas.Left="900" Canvas.Top="5"
            Padding="5,2" CornerRadius="4"
            Height="30">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.3" BlurRadius="5"/>
                </Border.Effect>

                <hc:SimpleStackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10" Height="36" Cursor="SizeAll" VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="Transparent"/>
                        </Border.Background>
                        <hc:SimpleStackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,2"/>
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,2"/>
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,2"/>
                        </hc:SimpleStackPanel>
                    </Border>

                    <!--Debug button-->
                    <Button x:Name="btnDebug" Visibility="Collapsed"
                            Style="{StaticResource ButtonIcon}" 
                            ToolTip="Debug/test functionality button"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="20"
                            hc:IconElement.Geometry="{StaticResource StarGeometry}" Click="btnDebug_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnFreeMode" 
                            Style="{StaticResource ButtonIcon}" 
                            ToolTip="Toggle Follow/Free Mode"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="20"
                            hc:IconElement.Geometry="{StaticResource ArrowsToCirceGeometry}" Click="btnFreeMode_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnLootSettings" 
                            Style="{StaticResource ButtonIcon}" 
                            ToolTip="Opens the loot settings"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Height="20"
                            hc:IconElement.Geometry="{StaticResource DollarSignGeometry}"
                            Click="btnLootSettings_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnLootFilter" 
                            Style="{StaticResource ButtonIcon}" 
                            ToolTip="Opens the loot filter panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource FilterGeometry}" Click="btnLootFilter_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnESPSettings" 
                            Style="{StaticResource ButtonIcon}" 
                            ToolTip="Opens the chams/fuser esp configuration panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource GlassesGeometry}" Click="btnESPSettings_Click"/>

                    <Button x:Name="btnMemoryWritingSettings"
                            Style="{StaticResource ButtonIcon}" 
                            ToolTip="Opens the memory writing configuration panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource WandMagicSparklesGeometry}"
                            Click="btnMemoryWritingSettings_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnGeneralSettings" 
                            Style="{StaticResource ButtonIcon}" 
                            ToolTip="Opens the general settings panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource GearGeometry}"
                            Click="btnGeneralSettings_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0" />

                    <Button x:Name="btnSearchSettings"
                            Style="{StaticResource ButtonIcon}"
                            ToolTip="Search settings (Ctrl+F)"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                            Click="btnSettingsSearch_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnRestart"
                            Style="{StaticResource ButtonIcon}"
                            ToolTip="Restarts the Radar for the current raid instance"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource ArrowsRotateGeometry}"
                            Click="btnRestart_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>
                    <Button x:Name="btnQuestPlanner"
                            Style="{StaticResource ButtonIcon}"
                            ToolTip="Opens the quest planner panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource MapGeometry}"
                            Click="btnQuestPlanner_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>
                    <Button x:Name="btnHideoutStash"
                            Style="{StaticResource ButtonIcon}"
                            ToolTip="Opens the hideout stash value panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource BoxGeometry}"
                            Click="btnHideoutStash_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>
                    <Button x:Name="btnWatchlist"
                            Style="{StaticResource ButtonIcon}"
                            ToolTip="Opens the player watchlist panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource EyeGeometry}"
                            Click="btnWatchlist_Click"/>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>
                    <Button x:Name="btnPlayerHistory"
                            Style="{StaticResource ButtonIcon}"
                            ToolTip="Opens the player history panel"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="32" Height="32"
                            Padding="6"
                            hc:IconElement.Width="18"
                            hc:IconElement.Geometry="{StaticResource ClockGeometry}"
                            Click="btnPlayerHistory_Click"/>
                </hc:SimpleStackPanel>
            </Border>
        </Canvas>

        <!-- general settings panel -->
        <Canvas Name="GeneralSettingsCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="GeneralSettingsPanel" 
                    Width="340" Height="600"
                    Canvas.Left="700" Canvas.Top="50"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:GeneralSettingsControl x:Name="GeneralSettingsControl"/>
            </Border>
        </Canvas>

        <!-- loot settings panel -->
        <Canvas Name="LootSettingsCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="LootSettingsPanel" 
                    Width="350" Height="450"
                    Canvas.Left="700" Canvas.Top="50"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:LootSettingsControl x:Name="LootSettingsControl"/>
            </Border>
        </Canvas>

        <!-- memory writing panel -->
        <Canvas Name="MemoryWritingCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="MemoryWritingPanel" 
                    Width="350" Height="550"
                    Canvas.Left="650" Canvas.Top="70"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:MemoryWritingControl x:Name="MemoryWritingControl"/>
            </Border>
        </Canvas>
        
        <!-- esp panel -->
        <Canvas Name="ESPCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="ESPPanel" 
                    Width="350" Height="550"
                    Canvas.Left="600" Canvas.Top="90"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:ESPControl x:Name="ESPControl"/>
            </Border>
        </Canvas>

        <!-- loot filter panel -->
        <Canvas Name="LootFilterCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="LootFilterPanel" 
                    Width="350" Height="450"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:LootFilterControl x:Name="LootFilterControl"/>
            </Border>
        </Canvas>
        
        <!-- settings search panel -->
        <Canvas Name="SettingsSearchCanvas" Panel.ZIndex="1000">
          <Canvas.Resources>
            <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
          </Canvas.Resources>

          <Border x:Name="SettingsSearchPanel"
                  Width="420" Height="560"
                  Canvas.Left="760" Canvas.Top="60"
                  CornerRadius="8"
                  Visibility="Collapsed"
                  Effect="{StaticResource PanelShadow}"
                  Background="Transparent"
                  BorderThickness="0">
            <local:SettingsSearchControl x:Name="SettingsSearchControl"/>
          </Border>
        </Canvas>       
        <!-- map setup panel -->
        <Canvas Name="MapSetupCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="MapSetupPanel"
                    Width="365" Height="145"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8"
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:MapSetupControl x:Name="MapSetupControl"/>
            </Border>
        </Canvas>

        <!-- quest planner panel -->
        <Canvas Name="QuestPlannerCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="QuestPlannerPanel"
                    Width="340" Height="600"
                    Canvas.Left="650" Canvas.Top="50"
                    CornerRadius="8"
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:QuestPlannerControl x:Name="QuestPlannerControl"/>
            </Border>
        </Canvas>

        <!-- hideout stash panel -->
        <Canvas Name="HideoutStashCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="HideoutStashPanel"
                    Width="540" Height="480"
                    Canvas.Left="500" Canvas.Top="70"
                    CornerRadius="8"
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:HideoutStashControl x:Name="HideoutStashControl"/>
            </Border>
        </Canvas>

        <!-- watchlist panel -->
        <Canvas Name="WatchlistCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="WatchlistPanel"
                    Width="350" Height="450"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:WatchlistControl x:Name="WatchlistControl"/>
            </Border>
        </Canvas>

        <!-- player history panel -->
        <Canvas Name="PlayerHistoryCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="PlayerHistoryPanel"
                    Width="490" Height="200"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:PlayerHistoryControl x:Name="PlayerHistoryControl"/>
            </Border>
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Width="360"
                      Margin="0,0,20,20">
            <hc:SimpleStackPanel x:Name="GrowlPanel"
                        hc:Growl.Token="MainGrowl"
                        Orientation="Vertical"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"/>
        </ScrollViewer>
    </Grid>
</Window>